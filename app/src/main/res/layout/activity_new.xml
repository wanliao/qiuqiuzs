<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_neu_main"
    tools:context=".NewActivity">

    <View
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-80dp"
        android:layout_marginEnd="-80dp"
        android:alpha="0.3"
        android:background="@drawable/bg_circle_decor" />

    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="-60dp"
        android:layout_marginBottom="-50dp"
        android:alpha="0.3"
        android:background="@drawable/bg_circle_decor" />

    <ScrollView
        android:id="@+id/layout_permission_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:paddingHorizontal="24dp"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="Hi You!"
                android:textColor="#4A5568"
                android:textSize="32sp"
                android:textStyle="bold"
                android:layout_marginTop="60dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="请选择一种方式授予文件访问权限"
                android:textColor="#8A9BB4"
                android:textSize="14sp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="40dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="28dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="方案 A: 安卓原生授权 (SAF)"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#2196F3"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="通过系统文件选择器授权，安卓11及以下支持"
                    android:textColor="#8A9BB4"
                    android:textSize="13sp"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="16dp"/>

                <Button
                    android:id="@+id/button_android_auth"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="去授权"
                    android:textColor="#2196F3"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_neu_btn"
                    android:stateListAnimator="@null"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="28dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="方案 B: Shizuku 授权"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#00C853"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="推荐方案：需要已激活 Shizuku，全安卓设备通用，需提前下载配置好shizuku，可哔哩哔哩搜索使用方案"
                    android:textColor="#8A9BB4"
                    android:textSize="13sp"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="16dp"/>

                <Button
                    android:id="@+id/button_shizuku"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="请求权限"
                    android:textColor="#00C853"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_neu_btn"
                    android:stateListAnimator="@null"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="方案 C: Root 权限"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FF5252"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="最高权限，直接读写所有文件。"
                    android:textColor="#8A9BB4"
                    android:textSize="13sp"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="16dp"/>

                <Button
                    android:id="@+id/button_root"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="检查 Root"
                    android:textColor="#FF5252"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_neu_btn"
                    android:stateListAnimator="@null"/>
            </LinearLayout>

            <TextView
                android:id="@+id/permission_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="当前状态：未获取权限"
                android:textColor="#E53E3E"
                android:textStyle="bold"
                android:textSize="14sp"
                android:padding="16dp" />

            <TextView
                android:id="@+id/tv_skip_auth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="暂无权限，继续使用其他功能 >"
                android:textColor="#A0AEC0"
                android:textSize="14sp"
                android:padding="20dp" />
        </LinearLayout>
    </ScrollView>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_action_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        tools:visibility="gone">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:scrollbars="none"
            android:paddingHorizontal="24dp"
            android:clipToPadding="false"
            android:paddingBottom="100dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="50dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Missing you for ten thousand years"
                    android:textColor="#4A5568"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="32dp"
                    android:text="光影之间"
                    android:textColor="#8A9BB4"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="32dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/button_delete_file"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_neu_btn"
                        android:stateListAnimator="@null"
                        android:text="重置资源"
                        android:textColor="#4A5568"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/tv_goto_other"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_neu_btn"
                        android:stateListAnimator="@null"
                        android:text="排名查询"
                        android:textColor="#4A5568"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="资源注入"
                    android:textColor="#718096"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <GridLayout
                    android:id="@+id/grid_layout_functions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:alignmentMode="alignBounds"
                    android:columnCount="2"
                    android:useDefaultMargins="false"></GridLayout>

            </LinearLayout>
        </ScrollView>

        <FrameLayout
            android:id="@+id/button_float_window"
            android:layout_width="76dp"
            android:layout_height="76dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_neu_circle"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_neu_play" />
        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>